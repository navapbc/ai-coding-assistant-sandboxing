;; agent.sb — deny-by-default Seatbelt profile for running CLI tools in isolation.
;;
;; This is the FALLBACK/reference profile (see docs/universal-sandbox-srt.md —
;; prefer @anthropic-ai/sandbox-runtime, which adds domain-filtered networking).
;;
;; Invoke via run-sandboxed.sh, which supplies the parameters:
;;   TARGET_DIR  absolute path to the workspace (the only writable project dir)
;;   HOME_DIR    absolute path to the user's home directory
;;
;; Rule evaluation is last-match-wins per operation: broad allows come first,
;; secret-path denies come LAST so nothing can re-allow them.
;;
;; NETWORK IS DENIED by (deny default). run-sandboxed.sh appends a network
;; section only when explicitly requested (--allow-net-proxy PORT), and even
;; then only to a localhost proxy port. Seatbelt cannot filter by domain —
;; domain filtering must happen in a proxy outside the sandbox.

(version 1)
(deny default)

;; --- process basics -------------------------------------------------------
(allow process-fork)
(allow process-exec)
(allow signal (target same-sandbox))
(allow sysctl-read)

;; Mach services needed by common CLI tools (DNS, preferences, logging).
;; Deliberately does NOT include securityd/Keychain services — the `security`
;; CLI and Keychain APIs must not work inside this sandbox.
(allow mach-lookup
  (global-name "com.apple.system.opendirectoryd.libinfo")
  (global-name "com.apple.system.notification_center")
  (global-name "com.apple.system.logger")
  (global-name "com.apple.logd")
  (global-name "com.apple.diagnosticd")
  (global-name "com.apple.cfprefsd.daemon")
  (global-name "com.apple.cfprefsd.agent")
  (global-name "com.apple.dnssd.service")
  (global-name "com.apple.SystemConfiguration.configd")
  (global-name "com.apple.coreservices.launchservicesd")
  (global-name "com.apple.FSEvents"))

;; --- filesystem: broad read, narrow write ---------------------------------
(allow file-read* file-read-metadata)

;; Writes: workspace, temp dirs, and terminal devices only.
(allow file-write* (subpath (param "TARGET_DIR")))
(allow file-write* (subpath "/private/tmp"))
(allow file-write* (regex #"^/private/var/folders/[^/]+/[^/]+/(T|C)(/|$)"))
(allow file-write-data
  (literal "/dev/null")
  (literal "/dev/zero")
  (literal "/dev/stdout")
  (literal "/dev/stderr"))
(allow file-read* file-write* file-ioctl (regex #"^/dev/tty"))
(allow file-write* (literal "/dev/dtracehelper"))
(allow pseudo-tty)

;; --- secret carve-outs: LAST so they always win ---------------------------
(deny file-read* file-write*
  (subpath (string-append (param "HOME_DIR") "/.ssh"))
  (subpath (string-append (param "HOME_DIR") "/.aws"))
  (subpath (string-append (param "HOME_DIR") "/.azure"))
  (subpath (string-append (param "HOME_DIR") "/.config/gcloud"))
  (subpath (string-append (param "HOME_DIR") "/.kube"))
  (subpath (string-append (param "HOME_DIR") "/.gnupg"))
  (subpath (string-append (param "HOME_DIR") "/.docker"))
  (subpath (string-append (param "HOME_DIR") "/Library/Keychains"))
  (subpath (string-append (param "HOME_DIR") "/.config/sops"))
  (literal (string-append (param "HOME_DIR") "/.netrc"))
  (literal (string-append (param "HOME_DIR") "/.npmrc"))
  (literal (string-append (param "HOME_DIR") "/.pypirc"))
  (literal (string-append (param "HOME_DIR") "/.bash_history"))
  (literal (string-append (param "HOME_DIR") "/.zsh_history")))

;; Sensitive file *types*, denied anywhere (including TARGET_DIR) — these are
;; extension-matched, not home-anchored, so they use regex rather than subpath.
;; Claude Code's own `denyRead` is literal-path-only and can't express these;
;; this Seatbelt regex is the OS-level equivalent for the wrapped tier.
;;   *.key            private keys / TLS keys
;;   *.sw[a-p]        vim swap files (may hold unsaved buffer contents of secrets)
(deny file-read* file-write*
  (regex #"\.key$")
  (regex #"\.sw[a-p]$"))

;; ~/.gitconfig is intentionally NOT denied here. git reads it for commit
;; identity (user.name/email), and commits happen inside the sandbox — denying
;; read would break them. Writes to it are already blocked (default-deny above),
;; which is what stops malicious credential-helper / url.insteadOf injection.
;; Don't store tokens in ~/.gitconfig; use a repo-scoped PAT kept out of reach.
