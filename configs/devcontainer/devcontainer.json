{
  "name": "AI Agent Sandbox (default-deny egress)",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "EGRESS_PROXY": "true"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "remoteUser": "vscode",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=agent-sandbox-claude-${devcontainerId},target=/home/vscode/.claude,type=volume",
    "source=agent-sandbox-codex-${devcontainerId},target=/home/vscode/.codex,type=volume",
    "source=agent-sandbox-copilot-${devcontainerId},target=/home/vscode/.copilot,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "EGRESS_MODE": "proxy",
    "EGRESS_TLS_TERMINATE": "false",
    "HTTP_PROXY": "http://127.0.0.1:15001",
    "HTTPS_PROXY": "http://127.0.0.1:15001",
    "NO_PROXY": "localhost,127.0.0.1,::1"
  },
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  }
}
